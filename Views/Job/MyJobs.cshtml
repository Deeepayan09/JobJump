@model IEnumerable<JobJump.Models.Job>

<h2 class="mb-4">My Jobs</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Post Job</a>

<div class="row">
@foreach (var job in Model)
{
    <div class="col-md-4 mb-4">
        <div class="card shadow">

            <div class="card-body">
                <h5>@job.Title</h5>
                <p>@job.Company</p>
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Edit" asp-route-id="@job.Id" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@job.Id" class="btn btn-danger btn-sm">Delete</a>
                <a asp-action="Applicants" asp-route-jobId="@job.Id" class="btn btn-info btn-sm">Applicants</a>
            </div>

        </div>
    </div>
}
</div>