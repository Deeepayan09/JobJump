@model IEnumerable<JobJump.Models.Job>

@{
    ViewData["Title"] = "Jobs";

    var appliedJobs = ViewBag.AppliedJobs as List<int>;
    var savedJobs = ViewBag.SavedJobs as List<int>;
}

<div class="container mt-4">

    <!-- PAGE TITLE -->
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">🚀 Available Jobs</h1>

        <p class="text-muted">
            Discover opportunities and apply instantly
        </p>
    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-center"
             role="alert">

            @TempData["Message"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    <!-- SEARCH BAR -->
    <form method="get"
          asp-action="Index"
          class="mb-5">

        <div class="row g-2">

            <div class="col-md-5">
                <input type="text"
                       name="search"
                       class="form-control"
                       placeholder="Search job title..." />
            </div>

            <div class="col-md-5">
                <input type="text"
                       name="company"
                       class="form-control"
                       placeholder="Search company..." />
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-dark w-100">
                    Search
                </button>
            </div>

        </div>
    </form>

    <!-- JOBS -->
    <div class="row">

        @foreach (var job in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card shadow border-0 h-100 rounded-4">

                    <!-- CARD BODY -->
                    <div class="card-body d-flex flex-column">

                        <div class="mb-3">

                            <h4 class="fw-bold">
                                @job.Title
                            </h4>

                            <h6 class="text-muted">
                                🏢 @job.Company
                            </h6>

                        </div>

                        <p class="text-secondary flex-grow-1">

                            @(job.Description.Length > 120
                                ? job.Description.Substring(0, 120) + "..."
                                : job.Description)

                        </p>

                    </div>

                    <!-- CARD FOOTER -->
                    <div class="card-footer bg-white border-0">

                        <!-- VIEW DETAILS -->
                        <a asp-action="Details"
                           asp-route-id="@job.Id"
                           class="btn btn-outline-primary btn-sm w-100 mb-2">

                            View Details

                        </a>

                        @if (User.IsInRole("Employee"))
                        {
                            <!-- ALREADY APPLIED -->
                            @if (appliedJobs != null &&
                           appliedJobs.Contains(job.Id))
                            {
                                <button class="btn btn-secondary btn-sm w-100 mb-2"
                                        disabled>

                                    Already Applied ✅

                                </button>
                            }
                            else
                            {
                                <!-- APPLY FORM -->
                                <form asp-action="Apply"
                                      asp-route-id="@job.Id"
                                      method="post"
                                      enctype="multipart/form-data">

                                    <!-- RESUME -->
                                    <div class="mb-2">

                                        <input type="file"
                                               name="resume"
                                               class="form-control form-control-sm"
                                               required />

                                    </div>

                                    <!-- APPLY -->
                                    <button type="submit"
                                            class="btn btn-success btn-sm w-100 mb-2">

                                        Apply Now

                                    </button>

                                </form>
                            }

                            <!-- SAVED JOB -->
                            @if (savedJobs != null &&
                           savedJobs.Contains(job.Id))
                            {
                                <button class="btn btn-dark btn-sm w-100"
                                        disabled>

                                    Saved ✅

                                </button>
                            }
                            else
                            {
                                <a asp-action="Save"
                                   asp-route-id="@job.Id"
                                   class="btn btn-outline-dark btn-sm w-100">

                                    Save Job

                                </a>
                            }
                        }

                    </div>

                </div>

            </div>
        }

    </div>

    <!-- NO JOBS -->
    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center mt-4">

            No jobs found 😢

        </div>
    }

</div>