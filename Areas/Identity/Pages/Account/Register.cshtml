@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-md-5">

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>Create a new account</h2>
            <hr />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- EMAIL -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- PASSWORD -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" placeholder="password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- CONFIRM PASSWORD -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="password" />
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- ROLE -->
            <div class="mb-3">
                <label>Select Role</label>
                <select asp-for="Input.Role" class="form-control">
                    <option value="">-- Select Role --</option>
                    <option value="Employee">Employee</option>
                    <option value="Employer">Employer</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="w-100 btn btn-primary">Register</button>

            <p class="mt-3 text-center">
                Already have an account? 
                <a asp-page="./Login">Login</a>
            </p>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}